{
  "compilerOptions": {
    "target": "ES2017", "lib": ["dom", "dom.iterable", "esnext"], "jsx": "preserve",
    "module": "esnext", "moduleResolution": "bundler", "strict": true, "noEmit": true,
    "esModuleInterop": true, "resolveJsonModule": true, "isolatedModules": true,
    "skipLibCheck": true, "incremental": true, "paths": { "@/*": ["./src/*"] },
    "plugins": [{ "name": "next" }]
  },
  "include": ["src/**/*", "next-env.d.ts"], "exclude": ["node_modules"]
}
